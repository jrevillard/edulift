    "@types/nodemailer": "^6.4.17",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.0.0",
    "hono": "^4.11.1",
