# Configuration pour déploiement avec les images Docker Hub
# Copiez ce fichier vers .env et modifiez les valeurs selon vos besoins

# Base de données PostgreSQL
POSTGRES_DB=edulift
POSTGRES_USER=edulift
POSTGRES_PASSWORD=changeme_secure_password

# Redis
REDIS_PASSWORD=changeme_redis_password

# Backend JWT
JWT_SECRET=changeme_very_long_jwt_secret_key_for_production

# Configuration Email (optionnel)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@edulift.com

# URLs Frontend
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_SOCKET_FORCE_POLLING=false

# URLs d'environnement (pour GitHub Actions)
STAGING_URL=https://staging.edulift.com
PRODUCTION_URL=https://edulift.com