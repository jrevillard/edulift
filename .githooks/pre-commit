#!/bin/bash

# Pre-commit hook for EduLift project
# Runs quality checks before allowing commit

set -e

echo "🔍 Running pre-commit checks..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

# Check if backend files are modified
BACKEND_CHANGED=false
FRONTEND_CHANGED=false

# Detect if we're in a worktree or main repo
# Track the actual directories where commands should run
BACKEND_DIR=""
FRONTEND_DIR=""

if [ -f "package.json" ] && grep -q '"name": "backend"' package.json 2>/dev/null; then
    # We're in backend directory (worktree or main repo)
    BACKEND_CHANGED=true
    BACKEND_DIR="$(pwd)"
elif [ -f "package.json" ] && grep -q '"name": "frontend"' package.json 2>/dev/null; then
    # We're in frontend directory (worktree or main repo)
    FRONTEND_CHANGED=true
    FRONTEND_DIR="$(pwd)"
else
    # We're in main repo root or worktree root, check paths
    for file in $STAGED_FILES; do
        if [[ $file == backend/* ]]; then
            BACKEND_CHANGED=true
            BACKEND_DIR="backend"
        fi
        if [[ $file == frontend/* ]]; then
            FRONTEND_CHANGED=true
            FRONTEND_DIR="frontend"
        fi
    done
fi

# Function to print colored output
print_success() {
    echo "✅ $1"
}

print_error() {
    echo "❌ $1"
}

print_info() {
    echo "ℹ️  $1"
}

# Backend checks
if [ "$BACKEND_CHANGED" = true ]; then
    echo ""
    print_info "Backend files modified. Running backend checks..."

    # Change to backend directory if needed
    if [ -n "$BACKEND_DIR" ]; then
        cd "$BACKEND_DIR"
    fi

    # Check if API files have changed
    API_FILES_CHANGED=$(git diff --cached --name-only | grep -E "(src/routes/|src/schemas/|src/controllers/)" | wc -l)

    if [ "$API_FILES_CHANGED" -gt 0 ]; then
        print_info "API files detected. Generating OpenAPI specification..."

        # Generate OpenAPI specification
        if npm run swagger:generate; then
            print_success "OpenAPI generation successful"

            # Check if swagger.json was actually modified
            if ! git diff --quiet docs/openapi/swagger.json; then
                print_info "Staging updated OpenAPI specification..."
                git add docs/openapi/swagger.json
            else
                print_info "OpenAPI specification already up to date"
            fi

            # Validate OpenAPI specification (fail on warnings too)
            LINT_OUTPUT=$(npx @redocly/cli lint docs/openapi/swagger.json --config .redocly.yaml 2>&1)
            LINT_EXIT_CODE=$?

            if [ $LINT_EXIT_CODE -ne 0 ]; then
                print_error "OpenAPI validation failed with errors"
                echo "$LINT_OUTPUT"
                echo "Please fix the OpenAPI errors before committing."
                exit 1
            fi

            # Check for warnings in output
            if echo "$LINT_OUTPUT" | grep -qi "warning\|warnings found"; then
                print_error "OpenAPI validation found warnings"
                echo "$LINT_OUTPUT"
                echo "Please fix the OpenAPI warnings before committing."
                exit 1
            fi

            print_success "OpenAPI validation passed (no errors or warnings)"
        else
            print_error "OpenAPI generation failed"
            echo "Please fix the generation errors before committing."
            exit 1
        fi
    fi

    # TypeScript type checking
    echo "🔎 Running TypeScript type checking..."
    if npm run typecheck; then
        print_success "TypeScript type checking passed"
    else
        print_error "TypeScript type checking failed"
        echo "Please fix the TypeScript errors before committing."
        exit 1
    fi

    # Linting
    echo "🔍 Running ESLint..."
    if npm run lint; then
        print_success "Linting passed"
    else
        print_error "Linting failed"
        echo "Please fix the linting errors before committing."
        echo "You can run 'npm run lint:fix' to automatically fix some errors."
        exit 1
    fi

    # Run tests - mandatory
    print_info "Running tests..."
    if npm run test:ci; then
        print_success "Tests passed"
    else
        print_error "Tests failed"
        echo "Please fix the failing tests before committing."
        echo "You can run 'npm test' to see the full test output."
        exit 1
    fi

fi

# Frontend checks
if [ "$FRONTEND_CHANGED" = true ]; then
    echo ""
    print_info "Frontend files modified. Running frontend checks..."

    # Change to frontend directory if needed
    if [ -n "$FRONTEND_DIR" ]; then
        cd "$FRONTEND_DIR"
    fi

    # TypeScript type checking
    echo "🔎 Running TypeScript type checking..."
    if npm run typecheck; then
        print_success "TypeScript type checking passed"
    else
        print_error "TypeScript type checking failed"
        echo "Please fix the TypeScript errors before committing."
        exit 1
    fi

    # Linting
    echo "🔍 Running ESLint..."
    if npm run lint; then
        print_success "Linting passed"
    else
        print_error "Linting failed"
        echo "Please fix the linting errors before committing."
        echo "You can run 'npm run lint:fix' to automatically fix some errors."
        exit 1
    fi

    # Run tests - mandatory
    print_info "Running tests..."
    if npm run test:run; then
        print_success "Tests passed"
    else
        print_error "Tests failed"
        echo "Please fix the failing tests before committing."
        echo "You can run 'npm test' to see the full test output."
        exit 1
    fi

fi

# If no code files were changed
if [ "$BACKEND_CHANGED" = false ] && [ "$FRONTEND_CHANGED" = false ]; then
    print_info "No code files modified, skipping checks"
fi

echo ""
print_success "All pre-commit checks passed! 🎉"
echo "Proceeding with commit..."